    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nlet combinedText = '';\nlet count = 0;\nfor (const item of allItems) {\n  const j = item.json;\n  const subject = j.subject || j.Subject || 'Sin asunto';\n  const from = j.from || j.From || '';\n  const body = j.textPlain || j.text || j.snippet || '';\n  const slice = typeof body === 'string' ? body.substring(0, 10000) : String(body).substring(0, 10000);\n  combinedText += '=== NEWSLETTER ' + (++count) + ' ===\\nDE: ' + from + '\\nASUNTO: ' + subject + '\\n\\n' + slice + '\\n\\n';\n}\nreturn [{ json: { combinedText: combinedText.substring(0, 160000), totalNewsletters: count } }];"
      },
      "id": "1a000004-0004-4000-8000-000000000004",
      "name": "Combinar Emails",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [860, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "YOUR_ANTHROPIC_API_KEY" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 16384, system: 'Eres el editor de INSIDE Life, newsletter semanal de Jorge Lorenzo sobre IA, automatizacion, deporte y emprendimiento.\\n\\nTU TAREA: Selecciona las 4-6 noticias mas relevantes de los emails y genera UNA edicion semanal completa en HTML.\\n\\nESTRUCTURA HTML OBLIGATORIA - usa exactamente estas clases CSS (el CSS ya esta en el template base del repo):\\n\\n- nav con topnav, nav-brand, nav-title, nav-badge, botnav\\n- modal suscripcion con sub-ov, sub-box, sub-form\\n- reader con id=sec-reader display:block padding-top:54px\\n- reader-back con back-btn\\n- nl-hero (fondo negro) con nl-ey, nl-h1 (con em para cursiva), nl-lead\\n- nl-idx con nl-idx-lbl y nl-idx-list de nl-idx-a\\n- articulos nl-art con art-hdr, art-n (numero rojo), art-src (fuente), art-h2, art-body\\n- callouts con callout + callout-lbl para lecciones practicas\\n- stats con .stats > .stat > .stat-n + .stat-l para datos numericos\\n- bullets con .bullets > li para listas\\n- una seccion nl-art-dark (fondo negro) para el tema mas impactante\\n- nl-foot con nl-foot-row, nl-sig, nl-flinks\\n\\nLINKS DEL FOOTER: LinkedIn https://www.linkedin.com/in/jorge-lorenzo-25ba3518/ | X https://x.com/JLbasket | Instagram https://www.instagram.com/jorgelorenzo.coach | Bio https://bio.jorgelorenzo.coach/ | jorge@insidelife.club\\n\\nDOCUMENTOS LEGALES en footer: documentos-legales/politica-de-privacidad.html | aviso-legal.html | politica-de-cookies.html | terminos-y-condiciones-de-uso.html | condiciones-generales-de-contratacion.html\\n\\nBREVO FORM ACTION: https://1e22ccbe.sibforms.com/serve/MUIFAImNtjNmHq5LpaK-cn-6fXZj5OMRIVi_N2j6sO7lOgYfku227N7flq9_ysaKRpGIzgIY8btJ3-h4kOQhmC5l9ozewXKT_MEvCEYOwN1TiDHU49xmvpWYfkrX92_-kK8SYfS45ADUH_hwHxFeEND8x42g9boudtaQwXph5CfjEf-XeKGJZS0xPc7pZjPPJn9U_0uFCE_NhFOn\\n\\nREGLAS:\\n- Escribe en espanol, tono directo y experto tipo amigo\\n- No inventes datos, solo usa lo que hay en los emails\\n- El nl-h1 debe ser un titular memorable y especifico de esta semana\\n- Numera los articulos con art-n del 1 al N\\n- Devuelve EXCLUSIVAMENTE el HTML completo sin markdown ni explicaciones', messages: [{ role: 'user', content: 'Genera la edicion de INSIDE Life con estos ' + $json.totalNewsletters + ' newsletters:\\n\\n' + $json.combinedText }] }) }}"
      },
      "id": "1a000005-0005-4000-8000-000000000005",
      "name": "Claude genera HTML",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, 300]
    },
    {
      "parameters": {
        "jsCode": "const root = $input.first().json;\nconst blocks = root.content || [];\nlet text = '';\nfor (const b of blocks) {\n  if (b && b.type === 'text' && b.text) text += b.text;\n}\ntext = text.replace(/^\\s*```html\\s*/i, '').replace(/\\s*```\\s*$/i, '').trim();\nif (!text || text.length < 500) throw new Error('Claude no devolvio HTML valido. Longitud: ' + text.length);\nreturn [{ json: { newsletterHtml: text, htmlLength: text.length } }];"
      },
