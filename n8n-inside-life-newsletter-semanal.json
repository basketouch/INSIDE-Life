        "jsonBody": "={{ JSON.stringify({ name: 'INSIDE Life - ' + new Date().toLocaleDateString('es-ES', {day:'numeric', month:'long', year:'numeric'}), subject: '🌟 Tu INSIDE Life de esta semana ya esta aqui', sender: { name: 'Jorge Lorenzo · INSIDE Life', email: 'jorge@insidelife.club' }, type: 'classic', htmlContent: '<html><body style=\"margin:0;padding:0;background:#f8f6f2;font-family:sans-serif;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td align=\"center\" style=\"padding:40px 20px;\"><table width=\"560\" style=\"background:#fff;\"><tr><td style=\"background:#111;padding:32px 40px;\"><div style=\"font-family:Georgia,serif;font-size:26px;font-weight:900;color:#fff;\">INSIDE Life</div><div style=\"font-family:monospace;font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:#e8401c;margin-top:6px;\">by Jorge Lorenzo · cada martes</div></td></tr><tr><td style=\"padding:32px 40px;\"><p style=\"font-size:15px;line-height:1.75;color:#333;margin:0 0 20px;\">Hola,</p><p style=\"font-size:15px;line-height:1.75;color:#333;margin:0 0 28px;\">Esta semana hay cosas interesantes que contarte sobre IA, automatizacion y todo lo que se mueve. Lo tienes ya listo.</p><table width=\"100%\"><tr><td align=\"center\" style=\"padding:4px 0 28px;\"><a href=\"https://insidelife.club/newsletter\" style=\"display:inline-block;background:#111;color:#fff;font-family:monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;padding:16px 32px;text-decoration:none;\">LEER ESTA EDICION &rarr;</a></td></tr></table><p style=\"font-size:13px;line-height:1.65;color:#767676;margin:0;\">Como siempre, sin ruido y sin relleno. Solo lo que vale la pena.</p><p style=\"font-family:Georgia,serif;font-size:15px;color:#111;margin:24px 0 4px;\">Jorge Lorenzo</p><p style=\"font-size:12px;color:#767676;font-style:italic;margin:0;\">INSIDE Life</p></td></tr><tr><td style=\"background:#f8f6f2;padding:18px 40px;border-top:1px solid #e8e4de;\"><p style=\"font-size:10px;color:#767676;margin:0;font-family:monospace;\">Recibes esto porque te suscribiste en insidelife.club &nbsp;|&nbsp; <a href=\"{unsubscribe}\" style=\"color:#767676;\">Darse de baja</a></p></td></tr></table></td></tr></table></body></html>', recipients: { listIds: [1] } }) }}"
