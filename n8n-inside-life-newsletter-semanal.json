        "jsCode": "const extractNode = $('Extraer HTML').first().json;\nconst shaNode = $input.first().json;\nconst sha = shaNode.sha || '';\nreturn [{ json: { newsletterHtml: extractNode.newsletterHtml, sha: sha } }];"
      },
